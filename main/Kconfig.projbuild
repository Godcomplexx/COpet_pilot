menu "CoPet Pilot"

    config COPET_WIFI_ENABLED
        bool "Enable Wi-Fi Station"
        default y
        help
            Start Wi-Fi in the background while local Desk Mode keeps running.

    config COPET_WIFI_SSID
        string "Wi-Fi SSID"
        default ""
        depends on COPET_WIFI_ENABLED
        help
            Stored only in the local sdkconfig file, which is ignored by Git.

    config COPET_WIFI_PASSWORD
        string "Wi-Fi password"
        default ""
        depends on COPET_WIFI_ENABLED
        help
            Stored only in the local sdkconfig file. Never print it to logs.

    config COPET_WIFI_SSID_2
        string "Wi-Fi SSID (2nd network, optional)"
        default ""
        depends on COPET_WIFI_ENABLED
        help
            Optional second known network. When two or more networks are set,
            the device scans the air on boot and reconnect and joins the
            highest-priority known network in range, so it works at more than
            one location without reflashing. Leave empty to disable.

    config COPET_WIFI_PASSWORD_2
        string "Wi-Fi password (2nd network)"
        default ""
        depends on COPET_WIFI_ENABLED
        help
            Password for the 2nd network. Local sdkconfig only; never logged.

    config COPET_WIFI_SSID_3
        string "Wi-Fi SSID (3rd network, optional)"
        default ""
        depends on COPET_WIFI_ENABLED
        help
            Optional third known network. Leave empty to disable.

    config COPET_WIFI_PASSWORD_3
        string "Wi-Fi password (3rd network)"
        default ""
        depends on COPET_WIFI_ENABLED
        help
            Password for the 3rd network. Local sdkconfig only; never logged.

    config COPET_MIC_ENABLED
        bool "Enable microphone listening reaction"
        default y
        help
            Capture ambient loudness from the INMP441 on the shared I2S bus and
            show the "listening" emotion when there is sustained sound (music)
            around. Best-effort: if the mic fails to start, event sounds still
            work. Turn off to run the speaker only.

    config COPET_MUSIC_DEBUG
        bool "Log microphone music-detector features"
        default y
        depends on COPET_MIC_ENABLED
        help
            Print level / ZCR / melodicity score once per second to the serial
            log. Use it to watch the detector while playing music and tune the
            thresholds in music_detector.h, then turn it off for normal use.

    config COPET_DIAGNOSTIC_BLE_ENABLED
        bool "Enable optional diagnostic BLE at boot"
        default n
        help
            BLE is not required for normal phone-free operation. Keeping it off
            leaves more RAM for network services on ESP32-WROOM-32.

    config COPET_WEATHER_ENABLED
        bool "Enable outdoor weather"
        default y
        depends on COPET_WIFI_ENABLED

    config COPET_WEATHER_LATITUDE
        string "Weather latitude"
        default "53.1959"
        depends on COPET_WEATHER_ENABLED
        help
            WGS84 latitude. Default is Samara.

    config COPET_WEATHER_LONGITUDE
        string "Weather longitude"
        default "50.1008"
        depends on COPET_WEATHER_ENABLED
        help
            WGS84 longitude. Default is Samara.

endmenu
